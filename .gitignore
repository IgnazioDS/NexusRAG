# Python bytecode
__pycache__/
*.py[cod]

# Virtual environments
.venv/

# Env files
.env

# Test artifacts
.pytest_cache/
.mypy_cache/

# Editable install artifacts
*.egg-info/

# Build artifacts
build/
dist/

# Dependency lock (generated; not needed for deployment)
uv.lock

# Editor settings
.vscode/
.DS_Store

# Python version pin (local dev only)
.python-version

# Firebase debug log (local emulator artifact)
firebase-debug.log

# Local runtime artifacts
var/

# Local audio artifacts
var/audio/

# Local document storage artifacts
var/documents/
var/ops/
var/evidence/
governance_artifacts/
tests/perf/reports/*
!tests/perf/reports/.gitkeep

# Frontend SDK artifacts
sdk/frontend/node_modules/
sdk/frontend/dist/
var/security/pip-audit.txt
.gitignore
.vercel
