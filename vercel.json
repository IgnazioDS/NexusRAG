{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/v1/(.*)", "dest": "/api/index.py" },
    { "src": "/api/stats", "dest": "/api/index.py" },
    { "src": "/api/benchmark-latest", "dest": "/api/index.py" },
    { "src": "/api/health", "dest": "/api/index.py" },
    { "src": "/api/heartbeat", "dest": "/api/index.py" },
    { "src": "/openapi.json", "dest": "/api/index.py" },
    { "src": "/docs", "dest": "/api/index.py" },
    { "src": "/health", "dest": "/api/index.py" },
    { "src": "/healthz", "dest": "/api/index.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
